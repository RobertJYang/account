        "/bin/sh -c /usr/bin/ssh-keygen -l -E SHA256 -f /dev/shm/tmp/publickeyconf_[0-9]+ > /dev/shm/tmp/publickeyhash_[0-9]+",
        "/bin/rm -rf /data/trust/home/[^/]+",
        "/bin/sh -c echo \".*\" > /dev/ttyS0"
