{
    "static_commands": [
        "/bin/cp -rpf /data/trust//home/ /dev/shm/backup_tmp/factory_backup/account/home",
        "/bin/cp -rpf /data/trust//home/ /dev/shm/backup_tmp/customization_backup/account/home",
        "/bin/cp -rpf /data/trust/weakdictionary /dev/shm/backup_tmp/factory_backup/account/weakdictionary",
        "/bin/cp -rpf /data/trust/weakdictionary /dev/shm/backup_tmp/customization_backup/account/weakdictionary",
        "/bin/cp -rpf /data/trust/pam_faillock /dev/shm/backup_tmp/factory_backup/account/pam_faillock",
        "/bin/cp -rpf /data/trust/pam_faillock /dev/shm/backup_tmp/customization_backup/account/pam_faillock",
        "/bin/rm -rf /data/trust/kerberos.pfx",
        "/bin/rm -rf /dev/shm/backup_tmp/factory_backup/account/pam_faillock",
        "/bin/rm -rf /dev/shm/backup_tmp/customization_backup/account/pam_faillock",
        "/bin/rm -rf /dev/shm/backup_tmp/factory_backup/account/weakdictionary",
        "/bin/rm -rf /dev/shm/backup_tmp/customization_backup/account/weakdictionary",
        "/bin/rm -rf /dev/shm/backup_tmp/factory_backup/account/home",
        "/bin/rm -rf /dev/shm/backup_tmp/customization_backup/account/home",
        "/bin/tar -zcvf /data/trust/opt/bmc/home.tar.gz -C /data/trust home",
